# TrueVoice - Environment Configuration Template
# DO NOT COMMIT REAL SECRETS. This is a template.

# --- Environment Configuration ---
# APP_ENV can be 'development' or 'production'
APP_ENV=development

# --- gRPC Microservices Configuration ---
# Audio Capture Service (C++)
AUDIO_CAPTURE_GRPC_HOST=127.0.0.1
AUDIO_CAPTURE_GRPC_PORT=50051

# Inference STT Service (Python)
INFERENCE_STT_GRPC_HOST=127.0.0.1
INFERENCE_STT_GRPC_PORT=50052

# AI Agent Service (Python)
AI_AGENT_GRPC_HOST=127.0.0.1
AI_AGENT_GRPC_PORT=50053

# --- Local AI Models Configuration ---
# Path to the faster-whisper model (local disk, no cloud)
WHISPER_MODEL_PATH=./models/whisper-base
# Set local LLM execution path (e.g. Ollama URL or local GGUF)
LLM_MODEL_PATH=http://127.0.0.1:11434

# --- UI & Debugging ---
# Enable verbose logging in Tauri frontend and backends
DEBUG_MODE=true
